{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echowaste.dev/schemas/menu-extraction.schema.json",
  "title": "MenuExtractionResult",
  "type": "object",
  "required": ["dishes", "uncertain_items", "overall_confidence"],
  "additionalProperties": false,
  "properties": {
    "dishes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dish_name", "confidence", "source_text"],
        "additionalProperties": false,
        "properties": {
          "dish_name": { "type": "string", "minLength": 1 },
          "section": {
            "type": ["string", "null"],
            "enum": ["starters", "entrees", "desserts", "breakfast", "buffet", "sides", "beverages", "other", null]
          },
          "station_hint": { "type": ["string", "null"], "maxLength": 80 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_text": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "uncertain_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_text", "reason"],
        "additionalProperties": false,
        "properties": {
          "source_text": { "type": "string" },
          "reason": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "notes": { "type": ["string", "null"], "maxLength": 500 }
  }
}
