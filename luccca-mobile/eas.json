{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "buildType": "simulator"
      },
      "env": {
        "ENVIRONMENT": "preview"
      }
    },
    "preview2": {
      "android": {
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "buildType": "simulator"
      }
    },
    "preview3": {
      "developmentClient": true
    },
    "production": {
      "android": {
        "buildType": "apk",
        "withoutCredentials": false,
        "credentialsSource": "local"
      },
      "ios": {
        "buildType": "ipa",
        "withoutCredentials": false,
        "credentialsSource": "local"
      },
      "env": {
        "ENVIRONMENT": "production"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "buildType": "simulator"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6739278450"
      },
      "android": {
        "packageIdentifier": "com.luccca.mobile",
        "serviceAccountKeyPath": "./service-account-key.json"
      }
    }
  }
}
