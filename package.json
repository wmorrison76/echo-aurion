{
  "name": "echo-aurion",
  "private": true,
  "type": "module",
  "pkg": {
    "assets": [
      "dist/spa/*"
    ],
    "scripts": [
      "dist/server/**/*.js"
    ]
  },
  "scripts": {
    "dev": "node scripts/dev-all.mjs",
    "dev:real-api": "node scripts/dev-all.mjs --real-api",
    "dev:frontend": "vite",
    "dev:backend": "tsx server/node-build.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:safe": "SAFE_MODE=true tsx scripts/validate-modules.ts && npm run dev",
    "electron:dev": "NODE_ENV=development electron electron/main.js",
    "electron:start": "electron electron/main.js",
    "electron:pack": "npm run build:client && electron-builder --config electron-builder.json",
    "electron:pack:mac": "npm run build:client && electron-builder --config electron-builder.json --mac dmg",
    "electron:pack:win": "npm run build:client && electron-builder --config electron-builder.json --win nsis",
    "electron:pack:linux": "npm run build:client && electron-builder --config electron-builder.json --linux AppImage",
    "build": "npm run build:client && npm run build:server",
    "build:client": "NODE_OPTIONS=--max-old-space-size=12288 vite build",
    "build:server": "vite build --config vite.config.server.ts",
    "build:safe": "SAFE_MODE=true tsx scripts/validate-modules.ts && npm run build",
    "start": "node dist/server/node-build.mjs",
    "test": "vitest --run",
    "lucca-doctor": "tsx lucca-doctor/run-all.ts",
    "lucca-doctor:collapsed-files": "tsx lucca-doctor/collapsed-files.ts",
    "lucca-doctor:circular-deps": "tsx lucca-doctor/circular-deps.ts",
    "lucca-doctor:missing-indexes": "tsx lucca-doctor/missing-indexes.ts",
    "lucca-doctor:missing-exports": "tsx lucca-doctor/missing-exports.ts",
    "lucca-doctor:alias-check": "tsx lucca-doctor/alias-check.ts",
    "test:smoke:system": "tsx scripts/smoke-system/index.ts",
    "test:smoke:system:once": "tsx scripts/smoke-system/index.ts --once",
    "test:smoke:system:once:light": "tsx scripts/smoke-system/index.ts --once --light",
    "test:smoke:system:once:fast": "tsx scripts/smoke-system/index.ts --once --fast",
    "test:smoke:system:light": "tsx scripts/smoke-system/index.ts --light",
    "test:smoke:system:disney": "tsx scripts/smoke-system/index.ts --disney",
    "test:smoke:system:disney:light": "tsx scripts/smoke-system/index.ts --disney --light",
    "test:smoke:war-grade": "tsx scripts/smoke-system/index.ts --war-grade",
    "test:smoke:war-grade:once": "tsx scripts/smoke-system/index.ts --war-grade --once",
    "test:smoke:aurion-ultra": "tsx scripts/smoke-system/index.ts --aurion-ultra",
    "test:smoke:aurion-ultra:once": "tsx scripts/smoke-system/index.ts --aurion-ultra --once",
    "test:smoke:links": "pnpm exec tsx scripts/smoke-system/run-all-link-smoke.ts",
    "test:smoke:links:panel-only": "SMOKE_SKIP_HTTP=1 pnpm exec tsx scripts/smoke-system/run-all-link-smoke.ts",
    "test:smoke:stress": "pnpm exec tsx scripts/smoke-system/stress-link-smoke.ts",
    "test:smoke:cycle": "pnpm exec tsx scripts/smoke-system/cycle-until-pass.ts",
    "test:smoke:ui": "playwright test --project=smoke-ui",
    "test:smoke:prospect-invoice-plate": "playwright test --project=prospect-invoice-plate",
    "test:smoke:prospect-to-plate": "vitest run tests/beo-traceability-prospect-to-plate.test.ts tests/full-automatic-e2e.test.ts --reporter=verbose",
    "test:smoke:full": "pnpm test:smoke:links && pnpm test:smoke:ui",
    "panel-load-report": "pnpm exec vite-node client/smoke-panel-load-runner.ts",
    "test:smoke:core": "vitest run client/lib/echo-ai3/cognitive/cognitive.test.ts client/lib/panel-controller.test.ts tests/full-automatic-e2e.test.ts tests/panel-registry.test.ts tests/beo-traceability-prospect-to-plate.test.ts server/routes/echo-ai3-chat.test.ts",
    "automation:run": "tsx scripts/automation/echo-automation.ts",
    "format.fix": "prettier --write .",
    "lint": "pnpm exec eslint . --max-warnings 0",
    "lint:fix": "pnpm exec eslint . --fix",
    "knip": "knip",
    "knip:exports": "knip --include exports --max-issues 50",
    "typecheck": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit --skipLibCheck -p tsconfig.smoke.json",
    "typecheck:incremental": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit --skipLibCheck --incremental -p tsconfig.smoke.json",
    "validate:modules": "tsx scripts/validate-modules.ts",
    "cleanup:modules": "tsx scripts/cleanup-module.ts",
    "health:check": "curl -s http://localhost:3000/api/module-health | jq .",
    "install:capstone": "node scripts/install_capstone.mjs",
    "echocoder:unlock": "tsx scripts/echocoder/unlock.ts",
    "echocoder:lock": "tsx scripts/echocoder/lock.ts",
    "echocoder:status": "tsx scripts/echocoder/status.ts",
    "echocoder:open": "tsx scripts/echocoder/open.ts",
    "echocoder:repair": "tsx scripts/echocoder/repair.ts",
    "echocoder:snapshot": "tsx scripts/echocoder/snapshot.ts",
    "echocoder:rollback": "tsx scripts/echocoder/rollback.ts",
    "db:test": "tsx server/database/test-connection.ts",
    "db:migrate": "tsx server/database/migrate.ts",
    "db:migrate:dev": "NODE_ENV=development tsx server/database/migrate.ts",
    "test:db": "vitest run tests/echo_resonance --reporter=verbose",
    "test:db:apply-migrations": "tsx scripts/test-db/apply-migrations.ts",
    "test:security": "tsx server/services/guardian-ai/test-military-security.ts",
    "test:api": "tsx server/test-api.ts",
    "test:guardian": "tsx server/services/guardian-ai/test-military-security.ts",
    "test:echo-ai3": "tsx server/services/echo-ai3/test-echo-ai3.ts",
    "test:sentient-echo": "tsx server/services/echo-ai3/test-sentient-echo.ts",
    "test:proactive": "tsx server/services/echo-ai3/test-proactive-insights.ts",
    "audit:panelhost-conflict": "npx tsx scripts/find-zustand-panel-consumers.ts",
    "audit:static": "npx tsx scripts/static-scan.ts",
    "audit:generate-contracts": "npx tsx scripts/generate-contracts.ts",
    "audit:crawl": "npx tsx scripts/crawler.ts",
    "audit:full": "npm run audit:static && npm run audit:generate-contracts && npm run audit:crawl && npx tsx scripts/merge-report.ts",
    "audit:report": "npx tsx scripts/merge-report.ts",
    "audit:sentry": "tsx scripts/sentry-audit.ts"
  },
