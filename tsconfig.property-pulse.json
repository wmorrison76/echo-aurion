{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": { "@/*": ["client/*"] }
  },
  "include": [
    "client/modules/PropertyPulse/**/*.ts",
    "client/modules/PropertyPulse/**/*.tsx"
  ]
}
