{
  "name": "echo-ops-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "metro": "react-native start",
    "build:android": "cd android && ./gradlew assembleRelease && cd ..",
    "build:ios": "cd ios && xcodebuild -workspace EchoOpsMobile.xcworkspace -scheme EchoOpsMobile -configuration Release && cd .."
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@supabase/supabase-js": "^2.58.0",
    "expo": "^51.0.0",
    "expo-barcode-scanner": "^13.0.0",
    "expo-blur": "^13.0.0",
    "expo-camera": "^15.0.0",
    "expo-constants": "^16.0.0",
    "expo-haptics": "^13.0.0",
    "expo-linking": "^6.0.0",
    "expo-splash-screen": "^0.27.0",
    "expo-status-bar": "^1.12.0",
    "nativewind": "^2.1.4",
    "react": "^18.2.0",
    "react-native": "^0.75.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^3.8.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-screens": "^3.29.0",
    "zustand": "^4.5.5",
    "zod": "^3.25.76",
    "axios": "^1.7.2",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@react-native/babel-preset": "0.75.0",
    "@react-native/eslint-config": "0.75.0",
    "@react-native/metro-config": "0.75.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.75.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "metro": "^0.80.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.0",
    "watchman": "^4.9.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
